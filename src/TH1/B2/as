import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;

// 1. Component (Giao diện chuẩn)
interface Tokenize {
    List<String> sto();
    String print();
}

// 2. Concrete Component (Thành phần cốt lõi chứa dữ liệu ban đầu)
class ChuoiDauTien implements Tokenize {
    private String chuoi;

    public ChuoiDauTien(String chuoi) {
        this.chuoi = chuoi;
    }

    @Override
    public List<String> sto() {
        // Trả về chuỗi nguyên bản dưới dạng một phần tử trong danh sách
        List<String> result = new ArrayList<>();
        result.add(chuoi);
        return result;
    }

    @Override
    public String print() {
        return "Chuỗi gốc";
    }
}

// 3. Base Decorator (Lớp bọc cơ sở)
abstract class TokenizeDecorator implements Tokenize {
    protected Tokenize tokenize;

    public TokenizeDecorator(Tokenize tokenize) {
        this.tokenize = tokenize;
    }

    @Override
    public List<String> sto() {
        // Gọi ngược về đối tượng bị bọc
        return tokenize.sto();
    }

    @Override
    public String print() {
        return tokenize.print();
    }
}

// 4. Concrete Decorators (Các tính năng bọc thêm)

// Tính năng 1: Loại bỏ dấu câu
class LoaiBoDauCau extends TokenizeDecorator {
    public LoaiBoDauCau(Tokenize tokenize) {
        super(tokenize);
    }

    // Hàm xử lý loại bỏ dấu câu
    private String FuncLoaiBoDauCau(String chuoi) {
        // Thay thế các dấu , . ! ? bằng chuỗi rỗng
        return chuoi.replaceAll("[.,!?]", "");
    }

    @Override
    public List<String> sto() {
        List<String> inputList = super.sto();
        List<String> result = new ArrayList<>();

        for (String s : inputList) {
            String cleanString = FuncLoaiBoDauCau(s);
            if (!cleanString.isEmpty()) {
                result.add(cleanString);
            }
        }
        return result;
    }

    @Override
    public String print() {
        return super.print() + " -> [Bỏ Dấu Câu]";
    }
}

// Tính năng 2: Tách từ
class TachTu extends TokenizeDecorator {
    public TachTu(Tokenize tokenize) {
        super(tokenize);
    }

    // Hàm xử lý tách từ theo khoảng trắng
    private List<String> FuncTachTu(String chuoi) {
        return Arrays.asList(chuoi.trim().split("\\s+"));
    }

    @Override
    public List<String> sto() {
        List<String> inputList = super.sto();
        List<String> result = new ArrayList<>();

        for (String s : inputList) {
            // Tách từng chuỗi trong danh sách cũ và gom lại vào danh sách mới
            result.addAll(FuncTachTu(s));
        }
        return result;
    }

    @Override
    public String print() {
        return super.print() + " -> [Tách Từ]";
    }
}

// Tính năng 3: Loại bỏ từ dừng (Stopwords)
class LoaiBoTuDung extends TokenizeDecorator {
    public LoaiBoTuDung(Tokenize tokenize) {
        super(tokenize);
    }

    // Hàm kiểm tra xem từ này có phải từ dừng không
    private boolean FuncLoaiBoTuDung(String chuoi) {
        // Giả lập danh sách stopwords cơ bản trong tiếng Việt
        List<String> stopWords = Arrays.asList("là", "và", "của", "thì", "mà", "những", "các");
        // Trả về true nếu KHÔNG NẰM TRONG danh sách stop words
        return !stopWords.contains(chuoi.toLowerCase());
    }

    @Override
    public List<String> sto() {
        List<String> inputList = super.sto();
        List<String> result = new ArrayList<>();

        for (String s : inputList) {
            // Chỉ thêm vào danh sách kết quả nếu không phải từ dừng
            if (FuncLoaiBoTuDung(s)) {
                result.add(s);
            }
        }
        return result;
    }

    @Override
    public String print() {
        return super.print() + " -> [Bỏ Từ Dừng]";
    }
}

// ==========================================
// Chạy thử nghiệm chương trình
// ==========================================
public class Main {
    public static void main(String[] args) {
        String vanBanGoc = "Xin chào, tôi là sinh viên của trường đại học! Đây là bài tập thiết kế phần mềm.";
        System.out.println("VĂN BẢN GỐC: " + vanBanGoc + "\n");

        // Bước 1: Khởi tạo dữ liệu gốc
        Tokenize pipeline = new ChuoiDauTien(vanBanGoc);

        // Bước 2: Bọc lớp Loại bỏ dấu câu
        pipeline = new LoaiBoDauCau(pipeline);

        // Bước 3: Bọc lớp Tách từ
        pipeline = new TachTu(pipeline);

        // Bước 4: Bọc lớp Loại bỏ từ dừng
        pipeline = new LoaiBoTuDung(pipeline);

        // IN KẾT QUẢ QUÁ TRÌNH
        System.out.println("CÁC BƯỚC ĐÃ XỬ LÝ: \n" + pipeline.print() + "\n");

        System.out.println("DANH SÁCH TOKEN CUỐI CÙNG: ");
        List<String> tokens = pipeline.sto();
        for (int i = 0; i < tokens.size(); i++) {
            System.out.println("[" + i + "] " + tokens.get(i));
        }
    }
}